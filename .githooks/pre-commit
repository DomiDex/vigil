#!/usr/bin/env bash
# Runs wiki-lint only when wiki/** or the linter itself is staged.
# Install once: git config core.hooksPath .githooks

set -euo pipefail

staged="$(git diff --cached --name-only --diff-filter=ACMR)"

if printf '%s\n' "$staged" | grep -qE '^(wiki/|scripts/wiki-lint\.ts$)'; then
  echo "pre-commit: linting wiki..."
  if ! bun run scripts/wiki-lint.ts; then
    echo "pre-commit: wiki-lint failed. Fix issues or bypass with --no-verify (discouraged)." >&2
    exit 1
  fi
fi

exit 0
